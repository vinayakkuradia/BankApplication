            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_yTRLER1BEey__cwKBS30rw" name="toString" specification="_yBih4B1BEey__cwKBS30rw">
              <ownedParameter xmi:id="_yTRLEh1BEey__cwKBS30rw" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <language>java</language>
              <body>StringBuilder builder = new StringBuilder();&#xD;
		builder.append(houseNumber).append(&quot; &quot;);&#xD;
		if(locality!=null)&#xD;
		builder.append(locality).append(&quot; &quot;);&#xD;
		if(landmark!=null)&#xD;
		builder.append(landmark).append(&quot; &quot;);&#xD;
		if(city!=null)&#xD;
		builder.append(city).append(&quot; &quot;);&#xD;
		builder.append(district).append(&quot; &quot;);&#xD;
		builder.append(state).append(&quot; &quot;);&#xD;
		if(pinCode!=null)&#xD;
		builder.append(pinCode);&#xD;
		return builder.toString();&#xD;
	</body>
            </ownedBehavior>
